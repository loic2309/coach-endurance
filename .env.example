# Identifiants Garmin Connect (utilisés uniquement pour la synchro, stockés en local)
GARMIN_EMAIL=ton.email@example.com
GARMIN_PASSWORD=ton_mot_de_passe

# Profil athlète
ATHLETE_NAME=Loic

# Dates de course (format AAAA-MM-JJ)
RACE_20KM_DATE=2027-05-30
RACE_703_DATE=2027-06-20

# Objectifs 20km (en minutes) : realiste = objectif principal, stretch = ambition haute
GOAL_20KM_REALISTIC_MIN=65
GOAL_20KM_STRETCH_MIN=62

# Objectif 70.3 (en minutes)
GOAL_703_MIN=300

# Records actuels (pour calculer les allures d'entrainement)
CURRENT_20KM_MIN=70
CURRENT_703_MIN=315

# Dossier de stockage (SQLite + token Garmin)
DATA_DIR=./data
